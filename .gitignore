# =============================================================================
# meta-autoresearch — .gitignore
# =============================================================================

# Python cache
# Created automatically by Python when running code.
# Machine-specific and useless for other contributors.
__pycache__/
*.pyc
*.pyo
*.pyd

# Virtual environment
# Created by uv to isolate project dependencies.
# Hundreds of MB of binaries — never commit to GitHub.
.venv/

# Secrets
# Contains API keys and other sensitive credentials.
# If pushed, a key is public within seconds.
.env

# Runtime files (generated at runtime, change constantly)
# run.log     : full output of each GPU training run
# results.tsv : live experiment log for the current batch (reset each batch)
# state.json  : current loop state (used to resume after interruption)
# program.md  : current research instructions (regenerated each batch)
run.log
results.tsv
state.json
program.md

# External reference (cloned repo for reference, not our code)
autoresearch/

# IDE
.vscode/
.idea/

# OS
Thumbs.db
.DS_Store

# Enforce consistent line endings across all operating systems
* text=auto eol=lf

# Source code
*.py   text eol=lf
*.toml text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf
*.lock text eol=lf
*.html text eol=lf
*.css  text eol=lf
*.js   text eol=lf

# Binary files — never convert
*.png  binary
*.jpg  binary
*.ico  binary
*.pdf  binary
